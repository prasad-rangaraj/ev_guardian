// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model BatteryReading {
  id            Int      @id @default(autoincrement())
  timestamp     DateTime @default(now())
  cell1         Float
  cell2         Float
  cell3         Float
  cell4         Float
  current       Float
  temperature   Float
  gas           Float
  batteryHealth Float
  anomalyScore  Float
  status        String   @default("Healthy")
  relay         String   @default("CONNECTED")

  @@map("battery_readings")
}

model AnomalyLog {
  id           Int      @id @default(autoincrement())
  timestamp    DateTime @default(now())
  anomalyScore Float
  status       String
  details      String?

  @@map("anomaly_logs")
}

model FaultLog {
  id          Int      @id @default(autoincrement())
  timestamp   DateTime @default(now())
  faultType   String
  severity    String
  actionTaken String
  value       String?

  @@map("fault_logs")
}
